<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- NuGet Configuration for Go Fishing Project -->
  
  <config>
    <!-- Allow prerelease versions -->
    <add key="nuget.org/use-stable-only" value="false" />
  </config>

  <packageSources>
    <!-- Official NuGet feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceCredentials>
    <!-- No authentication required for public feeds -->
  </packageSourceCredentials>

  <!-- Disable package verification for offline builds if needed -->
  <disabledPackageSources>
  </disabledPackageSources>

  <!-- Global packages folder (optional) -->
  <globalPackagesFolder>
  </globalPackagesFolder>

  <!-- Default push source -->
  <defaultPushSource value="https://api.nuget.org/v3/index.json" />
</configuration>
